{
  "info": {
    "name": "Piuda API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "patientId", "value": "1" },
    { "key": "logId", "value": "1" },
    { "key": "calendarId", "value": "1" },
    { "key": "postId", "value": "1" },
    { "key": "commentId", "value": "1" },
    { "key": "sessionId", "value": "1" },
    { "key": "galleryId", "value": "1" }
  ],
  "item": [
    {
      "name": "User",
      "item": [
        {
          "name": "회원가입 (보호자)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/users/signup",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"protector@test.com\",\n  \"password\": \"1234\",\n  \"name\": \"홍보호자\",\n  \"phone\": \"010-1111-2222\",\n  \"role\": \"PROTECTOR\"\n}"
            }
          }
        },
        {
          "name": "회원가입 (간병인)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/users/signup",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"caregiver@test.com\",\n  \"password\": \"1234\",\n  \"name\": \"김간병인\",\n  \"phone\": \"010-3333-4444\",\n  \"role\": \"CAREGIVER\",\n  \"experienceYears\": 3,\n  \"introduction\": \"성실한 간병인입니다.\"\n}"
            }
          }
        },
        {
          "name": "로그인",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "pm.collectionVariables.set('token', res.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/users/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"protector@test.com\",\n  \"password\": \"1234\"\n}"
            }
          }
        },
        {
          "name": "내 정보 조회",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/users/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "내 정보 수정",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/v1/users/me",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"홍보호자(수정)\",\n  \"phone\": \"010-9999-8888\",\n  \"password\": \"\"\n}"
            }
          }
        },
        {
          "name": "회원 탈퇴",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/users/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "랭킹 조회",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/users/ranking?limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "ranking"],
              "query": [{ "key": "limit", "value": "10" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Patient",
      "item": [
        {
          "name": "환자 등록",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "pm.collectionVariables.set('patientId', res.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/patients",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"홍환자\",\n  \"birthDate\": \"1940-05-15\",\n  \"gender\": \"MALE\",\n  \"dementiaStage\": \"경증\"\n}"
            }
          }
        },
        {
          "name": "초대코드로 환자 합류",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/patients/join",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"inviteCode\": \"ABCD1234\"\n}"
            }
          }
        },
        {
          "name": "내 환자 목록 조회",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/patients/my",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "환자 상세 조회",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/patients/{{patientId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "환자 정보 수정",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/v1/patients/{{patientId}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"홍환자(수정)\",\n  \"birthDate\": \"1940-05-15\",\n  \"gender\": \"MALE\",\n  \"dementiaStage\": \"중증\"\n}"
            }
          }
        },
        {
          "name": "환자 삭제",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/patients/{{patientId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "디바이스 연동",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/v1/patients/{{patientId}}/devices?deviceSerial=ESP32-001",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "patients", "{{patientId}}", "devices"],
              "query": [{ "key": "deviceSerial", "value": "ESP32-001" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "디바이스 연동 해제",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/patients/{{patientId}}/devices",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Device",
      "item": [
        {
          "name": "디바이스 등록",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/devices",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceSerial\": \"ESP32-001\"\n}"
            }
          }
        },
        {
          "name": "음성 기록 업로드",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/devices/ESP32-001/voice",
