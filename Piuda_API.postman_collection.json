    {
      "name": "CareAdvice (AI 상담)",
      "item": [
        {
          "name": "세션 생성 (sessionId 자동 저장)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if(res.sessionId) pm.collectionVariables.set('sessionId', res.sessionId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/patients/{{patientId}}/care-advice/sessions",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "세션 목록 조회",
          "request": {
            "method": "GET",
