{
  "info": {
    "name": "Piuda API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "patientId", "value": "1" },
    { "key": "logId", "value": "1" },
    { "key": "calendarId", "value": "1" },
    { "key": "postId", "value": "1" },
    { "key": "commentId", "value": "1" },
    { "key": "sessionId", "value": "1" },
    { "key": "galleryId", "value": "1" },
    { "key": "audioId", "value": "1" }
  ],
  "item": [
    {
      "name": "User",
      "item": [
        {
          "name": "회원가입",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/users/signup",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "data", "value": "{\"email\":\"test@test.com\",\"password\":\"test1234\",\"passwordConfirm\":\"test1234\",\"name\":\"홍길동\",\"nickname\":\"길동이\",\"phone\":\"010-1234-5678\",\"role\":\"PROTECTOR\"}", "type": "text", "contentType": "application/json" },
                { "key": "image", "type": "file", "src": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "로그인 (토큰 자동 저장)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if(res.accessToken) pm.collectionVariables.set('token', res.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/users/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@test.com\",\n  \"password\": \"test1234\"\n}"
            }
          }
        },
        {
          "name": "내 정보 조회",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/users/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "내 정보 수정",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/users/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "data", "value": "{\"name\":\"홍길동\",\"nickname\":\"새닉네임\",\"phone\":\"010-9999-9999\",\"introduction\":\"안녕하세요\"}", "type": "text", "contentType": "application/json" },
                { "key": "image", "type": "file", "src": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "회원 탈퇴",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/users/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "닉네임 중복 확인",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/check-nickname?nickname=길동이",
              "query": [{ "key": "nickname", "value": "길동이" }]
            }
          }
        },
        {
          "name": "랭킹 조회",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/ranking?limit=10",
              "query": [{ "key": "limit", "value": "10" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Patient",
      "item": [
        {
          "name": "환자 등록",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/patients",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"홍어르신\",\n  \"birthDate\": \"1940-05-15\",\n  \"gender\": \"MALE\",\n  \"dementiaStage\": \"중등도\",\n  \"relationship\": \"아들\"\n}"
            }
          }
        },
        {
          "name": "초대코드로 환자 합류",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/patients/join",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"inviteCode\": \"ABC12345\",\n  \"relationship\": \"간병인\"\n}"
            }
          }
        },
        {
          "name": "내 환자 목록 조회",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/patients/my",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "환자 상세 조회",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/patients/{{patientId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "환자 정보 수정",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/patients/{{patientId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"홍어르신\",\n  \"birthDate\": \"1940-05-15\",\n  \"gender\": \"MALE\",\n  \"dementiaStage\": \"중증\"\n}"
            }
          }
        },
        {
          "name": "환자 삭제",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/patients/{{patientId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "디바이스 연결",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/v1/patients/{{patientId}}/devices?deviceSerial=SN001",
              "query": [{ "key": "deviceSerial", "value": "SN001" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "디바이스 연결 해제",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/patients/{{patientId}}/devices",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "PatientMemory",
      "item": [
        {
          "name": "환자 신상/의료 정보 조회",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/patients/{{patientId}}/patient-memory",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "환자 신상/의료 정보 수정",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/patients/{{patientId}}/patient-memory",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bloodType\": \"A\",\n  \"longTermCareGrade\": 2,\n  \"dementiaType\": \"알츠하이머형\",\n  \"comorbidities\": \"고혈압\",\n  \"contraindications\": \"특이사항 없음\",\n  \"medicationInfo\": \"아리셉트 5mg\",\n  \"prnMedicationInfo\": \"\",\n  \"primaryDoctorInfo\": \"서울대병원 김의사\",\n  \"likes\": \"트로트 음악, 화투\",\n  \"dislikes\": \"시끄러운 환경\",\n  \"soothingWords\": \"괜찮아요, 잘 하고 계세요\",\n  \"ineffectiveWords\": \"왜 그래요\",\n  \"sundowningInfo\": \"오후 4시경 불안 증상\",\n  \"repetitiveBehaviors\": \"집에 가겠다고 반복\",\n  \"wanderingRoute\": \"현관 → 거실 → 베란다\",\n  \"emergencyContacts\": \"010-1234-5678 아들\",\n  \"preferredHospital\": \"서울대병원\",\n  \"specialNotes\": \"\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "DailyLog",
      "item": [
        {
          "name": "하루 일지 작성",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/patients/{{patientId}}/daily-logs",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "data", "value": "{\n  \"logDate\": \"2026-06-01\",\n  \"startTime\": \"09:00:00\",\n  \"endTime\": \"11:00:00\",\n  \"physicalHygiene\": true,\n  \"physicalBath\": false,\n  \"physicalMealHelp\": true,\n  \"physicalPositionChange\": false,\n  \"physicalMobilityHelp\": true,\n  \"physicalToiletHelp\": false,\n  \"physicalTotalMinutes\": 60,\n  \"cognitiveStimulationMinutes\": 30,\n  \"cognitiveLifeTogetherMinutes\": 20,\n  \"cognitiveBehaviorManagementMinutes\": 10,\n  \"emotionalCommunicationMinutes\": 0,\n  \"householdMealClean\": true,\n  \"householdPersonalHelp\": false,\n  \"householdTotalMinutes\": 30,\n  \"physicalFunctionTrend\": \"MAINTAINED\",\n  \"mealFunctionTrend\": \"IMPROVED\",\n  \"bowelIncontinenceCount\": 0,\n  \"urineIncontinenceCount\": 1,\n  \"specialNotes\": \"오늘 기분이 좋으셨음\"\n}", "type": "text", "contentType": "application/json" },
                { "key": "image", "type": "file", "src": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "환자 일지 목록 조회",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/patients/{{patientId}}/daily-logs",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "일지 상세 조회",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/daily-logs/{{logId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "일지 수정",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/daily-logs/{{logId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "data", "value": "{\n  \"startTime\": \"09:00:00\",\n  \"endTime\": \"12:00:00\",\n  \"physicalHygiene\": true,\n  \"physicalBath\": true,\n  \"physicalMealHelp\": true,\n  \"physicalPositionChange\": false,\n  \"physicalMobilityHelp\": false,\n  \"physicalToiletHelp\": true,\n  \"physicalTotalMinutes\": 90,\n  \"cognitiveStimulationMinutes\": 30,\n  \"cognitiveLifeTogetherMinutes\": 20,\n  \"cognitiveBehaviorManagementMinutes\": 10,\n  \"emotionalCommunicationMinutes\": 0,\n  \"householdMealClean\": true,\n  \"householdPersonalHelp\": true,\n  \"householdTotalMinutes\": 40,\n  \"physicalFunctionTrend\": \"WORSENED\",\n  \"mealFunctionTrend\": \"MAINTAINED\",\n  \"bowelIncontinenceCount\": 1,\n  \"urineIncontinenceCount\": 0,\n  \"specialNotes\": \"수정된 특이사항\"\n}", "type": "text", "contentType": "application/json" },
                { "key": "image", "type": "file", "src": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "일지 삭제",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/daily-logs/{{logId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
