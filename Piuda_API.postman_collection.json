    {
      "name": "Memory Gallery",
      "item": [
        {
          "name": "사진 업로드",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/patients/{{patientId}}/gallery",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
