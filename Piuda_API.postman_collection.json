              "formdata": [
                {
                  "key": "data",
                  "type": "text",
                  "value": "{\n  \"logDate\": \"2026-05-30\",\n  \"startTime\": \"09:00:00\",\n  \"endTime\": \"17:00:00\",\n  \"physicalHygiene\": true,\n  \"physicalBath\": false,\n  \"physicalMealHelp\": true,\n  \"physicalPositionChange\": false,\n  \"physicalMobilityHelp\": true,\n  \"physicalToiletHelp\": false,\n  \"physicalTotalMinutes\": 60,\n  \"cognitiveStimulationMinutes\": 30,\n  \"cognitiveLifeTogetherMinutes\": 20,\n  \"cognitiveBehaviorManagementMinutes\": 10,\n  \"emotionalCommunicationMinutes\": 0,\n  \"householdMealClean\": true,\n  \"householdPersonalHelp\": false,\n  \"householdTotalMinutes\": 30,\n  \"physicalFunctionTrend\": \"STABLE\",\n  \"mealFunctionTrend\": \"IMPROVING\",\n  \"bowelIncontinenceCount\": 0,\n  \"urineIncontinenceCount\": 1,\n  \"specialNotes\": \"특이사항 없음\"\n}",
                  "contentType": "application/json"
                },
                { "key": "image", "type": "file", "src": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "일지 목록 조회",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/patients/{{patientId}}/daily-logs",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "일지 상세 조회",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/daily-logs/{{logId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "일지 수정",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/v1/daily-logs/{{logId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "data",
                  "type": "text",
                  "value": "{\n  \"logDate\": \"2026-05-30\",\n  \"startTime\": \"09:00:00\",\n  \"endTime\": \"18:00:00\",\n  \"physicalHygiene\": true,\n  \"physicalBath\": true,\n  \"physicalMealHelp\": true,\n  \"physicalPositionChange\": false,\n  \"physicalMobilityHelp\": true,\n  \"physicalToiletHelp\": true,\n  \"physicalTotalMinutes\": 90,\n  \"cognitiveStimulationMinutes\": 30,\n  \"cognitiveLifeTogetherMinutes\": 20,\n  \"cognitiveBehaviorManagementMinutes\": 10,\n  \"emotionalCommunicationMinutes\": 0,\n  \"householdMealClean\": true,\n  \"householdPersonalHelp\": true,\n  \"householdTotalMinutes\": 45,\n  \"physicalFunctionTrend\": \"IMPROVING\",\n  \"mealFunctionTrend\": \"STABLE\",\n  \"bowelIncontinenceCount\": 0,\n  \"urineIncontinenceCount\": 0,\n  \"specialNotes\": \"수정된 특이사항\"\n}",
                  "contentType": "application/json"
                },
                { "key": "image", "type": "file", "src": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "일지 삭제",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/daily-logs/{{logId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
