            }
          }
        },
        {
          "name": "세션 메시지 목록 조회",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/care-advice/sessions/{{sessionId}}/messages",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "세션 삭제",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/care-advice/sessions/{{sessionId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
